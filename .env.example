APP_NAME=Plagiarism Detection Platform
APP_ENV=development
API_PREFIX=/api/v1

SQLITE_PATH=backend/storage/plagiarism_platform.db
PAN_DATASET_ROOT=backend/storage/pan2011
PROCESSED_DATASET_JSON=backend/storage/pan2011_processed.json

SIMILARITY_THRESHOLD_ORIGINAL=20
SIMILARITY_THRESHOLD_SUSPICIOUS=50
CHUNK_SIZE=6
MAX_SOURCE_CANDIDATES=10
CACHE_TTL_SECONDS=600

ENABLE_SEMANTIC_ENGINE=false
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2
